# ShopVivaliz - Configuração de Ambiente
APP_ENV=production
APP_URL=https://shopvivaliz.com.br
APP_DEBUG=false

# Google OAuth (Login com Google)
# Obtenha em: https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=seu-client-id-aqui.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=sua-client-secret-aqui

# Google Gemini (Chatbot Liz)
# Obtenha em: https://ai.google.dev/
GEMINI_API_KEY=sua-gemini-api-key-aqui
SQUAD_GEMINI_MODEL=gemini-1.5-flash

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=TEST-YOUR-ACCESS-TOKEN-HERE
MERCADOPAGO_PUBLIC_KEY=TEST-YOUR-PUBLIC-KEY-HERE
MERCADOPAGO_WEBHOOK_SECRET=YOUR-CRYPTO-KEY-HERE
SHOPVIVALIZ_BASE_URL=https://shopvivaliz.com.br
MERCADOPAGO_RETURN_URL=https://shopvivaliz.com.br/checkout/retorno

# Olist (Integração de produtos/pedidos)
OLIST_APP_KEY=sua-olist-app-key-aqui
OLIST_APP_SECRET=sua-olist-app-secret-aqui

# Tiny ERP
TINY_API_TOKEN=seu-tiny-api-token-aqui

# Melhor Envio
MELHOR_ENVIO_API_TOKEN=seu-melhor-envio-token-aqui
MELHOR_ENVIO_WEBHOOK_SECRET=seu-webhook-secret-aqui

# SMTP
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USERNAME=seu-email@dominio.com
SMTP_PASSWORD=sua-senha-email
SMTP_FROM_NAME=ShopVivaliz
SMTP_FROM_EMAIL=noreply@shopvivaliz.com.br

# Google Tag Manager
TAG_MANAGER=GTM-XXXXX
