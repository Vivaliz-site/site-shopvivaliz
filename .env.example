# ============================================
# ShopVivaliz Environment Configuration
# ============================================
# Copie este arquivo para .env e configure
# os valores de acordo com seu ambiente

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shopvivaliz
DB_USER=root
DB_PASSWORD=

# ============================================
# APIS EXTERNAS
# ============================================
# Melhor Envio (Frete)
MELHORENVIO_TOKEN=seu_token_aqui

# Olist (Marketplace)
OLIST_API_KEY=seu_api_key_aqui

# Tiny ERP (Catálogo)
TINY_API_TOKEN=seu_token_aqui

# Mercado Livre
MERCADOLIVRE_ACCESS_TOKEN=seu_token_aqui
MERCADOLIVRE_SELLER_ID=seu_seller_id

# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# ============================================
# LOJA
# ============================================
LOJA_WHATSAPP=5537999374112
LOJA_EMAIL=contato@shopvivaliz.com.br
LOJA_TELEFONE=+55 37 9999-9999

# ============================================
# SEGURANÇA
# ============================================
# SESSION SECRET
SESSION_SECRET=seu_secret_aleatorio_aqui

# ============================================
# DEBUG
# ============================================
DEBUG=false
LOG_LEVEL=info
