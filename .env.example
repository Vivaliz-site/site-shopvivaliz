# Mercado Pago - ShopVivaliz E-commerce
# Copie este arquivo para .env e preencha com seus valores reais

# ======================
# CREDENCIAIS MERCADO PAGO
# ======================

# Access Token (Autenticação da API)
# Obtenha em: https://www.mercadopago.com.br/account/credentials
# Prefixo TEST- para sandbox, APP_USR para produção
MERCADOPAGO_ACCESS_TOKEN=TEST-YOUR-ACCESS-TOKEN-HERE

# Public Key (Client-side, seguro publicar)
# Obtenha em: https://www.mercadopago.com.br/account/credentials
MERCADOPAGO_PUBLIC_KEY=TEST-YOUR-PUBLIC-KEY-HERE

# Webhook Secret (Crypto Key para validar assinatura)
# Obtenha em: https://www.mercadopago.com.br/account/integration/webhooks
MERCADOPAGO_WEBHOOK_SECRET=YOUR-CRYPTO-KEY-HERE

# URL publica HTTPS usada em retorno e webhook
SHOPVIVALIZ_BASE_URL=https://seu-dominio.com.br
MERCADOPAGO_RETURN_URL=https://seu-dominio.com.br/checkout/retorno

# ======================
# APLICAÇÃO
# ======================
APP_ENV=sandbox
APP_URL=https://seu-dominio.com.br
APP_DEBUG=false
