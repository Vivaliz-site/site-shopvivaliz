# ShopVivaliz - Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores reais

# Ambiente
APP_ENV=development
APP_DEBUG=true
APP_URL=https://dev.shopvivaliz.com.br

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shopvivaliz
DB_USER=root
DB_PASS=

# APIs de IA
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_REASONING_EFFORT=minimal

# Email (Titan SMTP)
MAIL_HOST=smtp.titan.email
MAIL_PORT=465
MAIL_USER=agentes@shopvivaliz.com.br
MAIL_PASS=

# FTP Deploy
FTP_SERVER=
FTP_USERNAME=
FTP_PASSWORD=
FTP_PORT=21
FTP_REMOTE_DIR=/

# Integrações
OLIST_API_KEY=
OLIST_SECRET=
# Usadas por claude/api/sync-olist-products.php (classe OlistSync) e
# claude/api/olist/auto-sync.php
OLIST_CLIENT_ID=
OLIST_CLIENT_SECRET=
# Bridge OlistSync -> Medusa (rotas /admin exigem login, não API key estática)
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_EMAIL=
MEDUSA_ADMIN_PASSWORD=
SHOPEE_API_KEY=
SHOPEE_SECRET=
TIKTOK_SERVICE_ID=
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URL=https://dev.shopvivaliz.com.br
TIKTOK_AUTH_REGION=row
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_SHOP_CIPHER=
TIKTOK_SHOP_ID=
MELHORENVIO_API_KEY=

# Segurança
SESSION_SECRET=
CSRF_TOKEN_NAME=csrf_token
JWT_SECRET=

# Cache
CACHE_DRIVER=file
CACHE_TTL=3600

# Logging
LOG_LEVEL=debug
LOG_PATH=./logs
LOG_MAX_SIZE=10485760

# Features
ENABLE_OAUTH=true
ENABLE_CART_PERSISTENCE=true
ENABLE_WISHLIST=true
ENABLE_LIVE_CHAT=true
ENABLE_RECOMMENDATIONS=true

# Agentes IA
AGENTS_ENABLED=true
AGENTS_CONCURRENT=3
AGENTS_TIMEOUT=120
AGENTS_RETRY=3

# Monitor
MONITOR_ENABLED=true
MONITOR_URL=https://dev.shopvivaliz.com.br/admin/monitor/

# MedusaJS -> EHA webhook bridge (claude/api/medusa-webhook.php)
# Deve ser o MESMO valor configurado em EHA_WEBHOOK_SECRET no .env do backend
# Medusa (claude/medusa/apps/backend/.env), senão o webhook responde 401.
EHA_WEBHOOK_SECRET=
