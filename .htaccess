# ShopVivaliz - Apache configuration
# Last updated: 2026-07-09
# Performance & Security Best Practices

# === SECURITY: Block sensitive files ===
<FilesMatch "^(\.env|\.env\.|\.htaccess|\.git|composer\.(json|lock)|package\.json|webpack\.config)">
    Require all denied
</FilesMatch>

<FilesMatch "^config/.*\.php$">
    Require all denied
</FilesMatch>

# === SECURITY: Prevent directory listings ===
Options -Indexes

# === SECURITY: Disable PHP execution in upload directories ===
<Directory ~"^.*/(uploads|tmp|temp)">
    php_flag engine off
    AddType text/plain .php .php3 .php4 .php5 .phtml
</Directory>

# === CHARSET: UTF-8 for all text files ===
AddCharset UTF-8 .html .txt .php .json .xml .css .js .svg

# === ERROR PAGES: Brand-aware error pages ===
ErrorDocument 400 /400.php
ErrorDocument 403 /403.php
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php
ErrorDocument 503 /503.php

# === HEADERS: Security & Performance ===
<IfModule mod_headers.c>
    # HTTPS enforcement
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Clickjacking protection
    Header always set X-Frame-Options "DENY"

    # MIME type sniffing protection
    Header always set X-Content-Type-Options "nosniff"

    # XSS protection
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Feature Policy (Permissions Policy)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # Remove server info
    Header always unset X-Powered-By
    Header unset X-Powered-By

    # Enable CORS for fonts
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>

    # Cache busting for versioned assets
    <FilesMatch "\.(js|css|webp|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Short-lived cache for HTML
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Nunca expor arquivos internos de configuracao
    RewriteRule ^config/ - [F,L]

    # Mantem o dashboard operacional isolado na subpasta /claude/
    RewriteRule ^claude/?$ claude/index.php [L]
    RewriteRule ^claude/(.*)$ claude/$1 [L]

    # Normaliza URLs legadas para as rotas canonicas
    RewriteRule ^carrinho\.php$ /carrinho [R=301,L]
    RewriteRule ^checkout\.php$ /checkout [R=301,L]

    # Nao reescrever arquivos e diretorios reais
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Mercado Livre OAuth
    RewriteRule ^api/ml/login/?$ api/ml/login.php [L]
    RewriteRule ^api/ml/callback/?$ api/ml/callback.php [L,QSA]
    RewriteRule ^api/ml/token/status/?$ api/ml/token.php [L]
    RewriteRule ^api/ml/token/refresh/?$ api/ml/token.php [L]
    RewriteRule ^api/ml/me/?$ api/ml/me.php [L]
    RewriteRule ^api/ml/webhook/?$ api/ml/webhook.php [L,QSA]
    RewriteRule ^api/ml/products/?$ api/ml/products.php [L,QSA]
    RewriteRule ^api/ml/optimizer/?$ api/ml/optimizer.php [L,QSA]
    RewriteRule ^api/maintenance/opcache-reset/?$ api/maintenance/opcache-reset.php [L,QSA]
    RewriteRule ^admin/mercadolivre/?$ admin/mercadolivre.php [L]

    # Rotas principais da loja
    RewriteRule ^$ index.php [L]
    RewriteRule ^home/?$ home.php [L]
    RewriteRule ^produtos/?$ catalogo.php [L]
    RewriteRule ^catalogo/?$ catalogo.php [L]
    RewriteRule ^carrinho/?$ carrinho/index.php [L]
    RewriteRule ^checkout/?$ checkout-v2/index.php [L]
    RewriteRule ^sobre/?$ sobre/index.php [L]
    RewriteRule ^contato/?$ contato/index.php [L]
    RewriteRule ^faq/?$ faq/index.php [L]
    RewriteRule ^blog/?$ blog/index.php [L]
    RewriteRule ^politica-privacidade/?$ politica-privacidade/index.php [L]
    RewriteRule ^produto/?$ produto.php [L]
    RewriteRule ^produto/([a-z0-9][a-z0-9\-]*)/?$ produto.php?slug=$1 [L,QSA]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
</IfModule>
