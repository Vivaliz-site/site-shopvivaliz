# ShopVivaliz - Configuração Apache Minimalista
# IMPORTANTE: Este é um .htaccess simples que funciona em HostGator
# Segurança avançada será via PHP (config/constants.php)

# Bloquear acesso a arquivos sensíveis
<FilesMatch "\.env|\.htaccess|config/.*\.php">
    Order allow,deny
    Deny from all
</FilesMatch>

# Charset UTF-8
AddCharset UTF-8 .html .txt .php .json

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Nao reescrever arquivos e diretorios reais
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Mercado Livre OAuth
    RewriteRule ^api/ml/login/?$ api/ml/login.php [L]
    RewriteRule ^api/ml/callback/?$ api/ml/callback.php [L,QSA]
    RewriteRule ^api/ml/token/status/?$ api/ml/token.php [L]
    RewriteRule ^api/ml/token/refresh/?$ api/ml/token.php [L]
    RewriteRule ^api/ml/me/?$ api/ml/me.php [L]
    RewriteRule ^api/ml/webhook/?$ api/ml/webhook.php [L,QSA]

    # Rotas da loja
    RewriteRule ^catalogo/?$ catalogo.php [L]
    RewriteRule ^produto/?$ produto.php [L]
    RewriteRule ^carrinho/?$ carrinho.php [L]
    RewriteRule ^checkout/?$ checkout.php [L]
    RewriteRule ^pedido-criar/?$ pedido-criar.php [L]
</IfModule>

# Gzip compression (se disponível)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>

# Cache control (opcional)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
</IfModule>
