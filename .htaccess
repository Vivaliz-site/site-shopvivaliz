# ShopVivaliz - Apache routing

# Bloquear acesso a arquivos sensiveis
<FilesMatch "^(\.env|\.htaccess)$">
    Require all denied
</FilesMatch>

<FilesMatch "^config/.*\.php$">
    Require all denied
</FilesMatch>

# Charset UTF-8
AddCharset UTF-8 .html .txt .php .json

<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Uniform session-cookie protection for every PHP entry point. Lax preserves
# OAuth/payment return flows while blocking cross-site subrequests.
<IfModule mod_php.c>
    php_flag session.use_strict_mode On
    php_flag session.use_only_cookies On
    php_flag session.cookie_httponly On
    php_flag session.cookie_secure On
    php_value session.cookie_samesite Lax
    php_flag expose_php Off
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Nunca expor arquivos internos de configuracao e operacao
    RewriteRule ^config/ - [F,L]
    RewriteRule ^storage/ - [F,L]
    RewriteRule ^logs/ - [F,L]

    # Valida frete no servidor antes de criar o pedido
    RewriteRule ^api/orders/create\.php$ api/orders/create-validated.php [L]

    # Mantem o dashboard operacional isolado na subpasta /claude/
    RewriteRule ^claude/?$ claude/index.php [L]
    RewriteRule ^claude/(.*)$ claude/$1 [L]

    # Normaliza URLs legadas para as rotas canonicas
    RewriteRule ^carrinho\.php$ /carrinho [R=301,L]
    RewriteRule ^checkout\.php$ /checkout [R=301,L]

    # Nao reescrever arquivos e diretorios reais
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Cart API endpoints
    RewriteRule ^api/cart/validate/?$ api/cart/validate.php [L,QSA]
    RewriteRule ^api/cart/sync/?$ api/cart/sync.php [L,QSA]

    # Mercado Livre OAuth
    RewriteRule ^api/ml/login/?$ api/ml/login.php [L]
    RewriteRule ^api/ml/callback/?$ api/ml/callback.php [L,QSA]
    RewriteRule ^api/ml/token/status/?$ api/ml/token.php [L]
    RewriteRule ^api/ml/token/refresh/?$ api/ml/token.php [L]
    RewriteRule ^api/ml/me/?$ api/ml/me.php [L]
    RewriteRule ^api/ml/webhook/?$ api/ml/webhook.php [L,QSA]
    RewriteRule ^api/ml/products/?$ api/ml/products.php [L,QSA]
    RewriteRule ^api/ml/optimizer/?$ api/ml/optimizer.php [L,QSA]
    RewriteRule ^api/maintenance/opcache-reset/?$ api/maintenance/opcache-reset.php [L,QSA]
    RewriteRule ^admin/mercadolivre/?$ admin/mercadolivre.php [L]

    # Rotas principais da loja
    RewriteRule ^$ index.php [L]
    RewriteRule ^home/?$ home.php [L]
    RewriteRule ^produtos/?$ catalogo.php [L]
    RewriteRule ^catalogo/?$ catalogo.php [L]
    RewriteRule ^carrinho/?$ carrinho.php [L]
    RewriteRule ^checkout/?$ checkout.php [L]
    RewriteRule ^sobre/?$ sobre/index.php [L]
    RewriteRule ^contato/?$ contato/index.php [L]
    RewriteRule ^faq/?$ faq/index.php [L]
    RewriteRule ^blog/?$ blog/index.php [L]
    RewriteRule ^politica-privacidade/?$ politica-privacidade/index.php [L]
    RewriteRule ^produto/?$ produto.php [L]
    RewriteRule ^produto/([a-z0-9][a-z0-9\-]*)/?$ produto.php?slug=$1 [L,QSA]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/avif "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
</IfModule>
