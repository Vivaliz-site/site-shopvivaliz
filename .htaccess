# ShopVivaliz - Configuração Apache Minimalista
# IMPORTANTE: Este é um .htaccess simples que funciona em HostGator
# Segurança avançada será via PHP (config/constants.php)

# Bloquear acesso a arquivos sensíveis
<FilesMatch "\.env|\.htaccess|config/.*\.php">
    Order allow,deny
    Deny from all
</FilesMatch>

# Charset UTF-8
AddCharset UTF-8 .html .txt .php .json

# Gzip compression (se disponível)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>

# Cache control (opcional)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
</IfModule>
