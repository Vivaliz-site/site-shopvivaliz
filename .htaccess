# ShopVivaliz - Apache routing

# Bloquear acesso a arquivos sensiveis
<FilesMatch "^(\.env|\.htaccess)$">
    Require all denied
</FilesMatch>

<FilesMatch "^config/.*\.php$">
    Require all denied
</FilesMatch>

# Charset UTF-8
AddCharset UTF-8 .html .txt .php .json

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Mantem o dashboard operacional isolado na subpasta /claude/
    RewriteRule ^claude/?$ claude/index.php [L]
    RewriteRule ^claude/(.*)$ claude/$1 [L]

    # Nao reescrever arquivos e diretorios reais
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Mercado Livre OAuth
    RewriteRule ^api/ml/login/?$ api/ml/login.php [L]
    RewriteRule ^api/ml/callback/?$ api/ml/callback.php [L,QSA]
    RewriteRule ^api/ml/token/status/?$ api/ml/token.php [L]
    RewriteRule ^api/ml/token/refresh/?$ api/ml/token.php [L]
    RewriteRule ^api/ml/me/?$ api/ml/me.php [L]
    RewriteRule ^api/ml/webhook/?$ api/ml/webhook.php [L,QSA]

    # Rotas principais da loja
    RewriteRule ^$ index.php [L]
    RewriteRule ^home/?$ home.php [L]
    RewriteRule ^produtos/?$ catalogo.php [L]
    RewriteRule ^catalogo/?$ catalogo.php [L]
    RewriteRule ^carrinho/?$ carrinho/index.php [L]
    RewriteRule ^checkout/?$ checkout/index.php [L]
    RewriteRule ^sobre/?$ sobre/index.php [L]
    RewriteRule ^contato/?$ contato/index.php [L]
    RewriteRule ^faq/?$ faq/index.php [L]
    RewriteRule ^blog/?$ blog/index.php [L]
    RewriteRule ^politica-privacidade/?$ politica-privacidade/index.php [L]
    RewriteRule ^produto/?$ produto.php [L]
    RewriteRule ^produto/([a-z0-9][a-z0-9\-]*[0-9]+)/?$ produto.php?slug=$1 [L,QSA]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
</IfModule>
