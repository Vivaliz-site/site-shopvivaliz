{
  "roo-cline.useAgentRules": true,
  "roo-cline.autoImportSettingsPath": "~/site-shopvivaliz/config/roo-autonomous-settings.json",
  "roo-cline.allowedCommands": [
    "git status",
    "git branch",
    "git checkout",
    "git switch",
    "git fetch",
    "git pull",
    "git add",
    "git commit",
    "git push",
    "git diff",
    "git show",
    "git log",
    "rg",
    "Get-ChildItem",
    "Get-Content",
    "Set-Location",
    "Select-String",
    "Test-Path",
    "Resolve-Path",
    "Copy-Item",
    "Move-Item",
    "New-Item",
    "php",
    "python",
    "node",
    "npm",
    "composer",
    "curl"
  ],
  "roo-cline.deniedCommands": [
    "git push origin main",
    "git push origin HEAD:main",
    "git push --force",
    "git push -f",
    "git reset --hard",
    "git checkout --",
    "git clean",
    "git branch -D",
    "Remove-Item -Recurse",
    "Remove-Item -Force",
    "del /f",
    "rmdir /s",
    "Format-Volume",
    "diskpart"
  ],
  "roo-cline.commandExecutionTimeout": 600,
  "roo-cline.preventCompletionWithOpenTodos": false,
  "terminal.integrated.allowInUntrustedWorkspace": true,
  "geminicodeassist.rules": "full access and full permission",
  "python-envs.pythonProjects": [
    {
      "path": ".",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    }
  ],
  "claudeCode.useTerminal": true
}