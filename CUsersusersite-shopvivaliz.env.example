# ====================================
# SHOPEE API - CREDENCIAIS
# ====================================
# Copie este arquivo para .env e preencha com suas credenciais reais
# Obtenha em: https://seller.shopee.com.br/ > Configuracoes > Open API

# Partner ID da sua conta Shopee
SHOPEE_PARTNER_ID=seu_partner_id_aqui

# Partner Key (chave secreta)
SHOPEE_PARTNER_KEY=sua_partner_key_aqui

# Shop ID (ID da sua loja)
SHOPEE_SHOP_ID=seu_shop_id_aqui

# Access Token (token de autenticacao)
SHOPEE_ACCESS_TOKEN=seu_access_token_aqui

# ====================================
# CONFIGURACOES OPCIONAIS
# ====================================

# Modo de operacao (simulado ou real)
SHOPEE_MODE=simulado

# Numero maximo de produtos por ciclo
SHOPEE_BATCH_SIZE=50

# Timeout para requisicoes (segundos)
SHOPEE_TIMEOUT=30

# Debug mode
DEBUG=false
