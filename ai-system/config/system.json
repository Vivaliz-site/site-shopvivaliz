{
  "system": {
    "name": "ShopVivaliz Hybrid AI",
    "version": "1.0.0",
    "environment": "local",
    "repo_path": "C:/site-shopvivaliz"
  },
  "models": {
    "local": {
      "endpoint": "http://localhost:11434",
      "model": "mistral:7b-instruct-q4_K_M",
      "context_size": 8192,
      "hardware": {
        "gpu": "NVIDIA MX110",
        "gpu_vram_gb": 2,
        "system_ram_gb": 32,
        "cpu_threads": 8
      }
    },
    "api": {
      "openai": {
        "model": "gpt-4o-mini",
        "cost_per_1m_input": 0.15,
        "cost_per_1m_output": 0.60
      },
      "anthropic": {
        "model": "claude-opus-4-1",
        "cost_per_1m_input": 15,
        "cost_per_1m_output": 75
      },
      "google": {
        "model": "gemini-pro",
        "cost_per_1m_input": 0.5,
        "cost_per_1m_output": 1.5
      }
    }
  },
  "costs": {
    "daily_limit": 10.0,
    "weekly_limit": 50.0,
    "monthly_limit": 200.0,
    "alert_at_percent": 80,
    "block_at_percent": 100
  },
  "routing": {
    "simple_tasks": "ollama",
    "medium_tasks": "ollama_with_fallback",
    "complex_tasks": "openai_or_anthropic",
    "critical_tasks": "anthropic_with_approval"
  },
  "agents": {
    "enabled": [
      "orchestrator",
      "backend",
      "frontend",
      "database",
      "devops",
      "security",
      "tester",
      "integrations",
      "seo",
      "auditor"
    ],
    "concurrent_limit": 5,
    "memory_per_agent_kb": 800
  },
  "memory": {
    "type": "sqlite",
    "upgrade_to": "qdrant",
    "retention_days": 90,
    "auto_cleanup": true
  },
  "integrations": {
    "github": {
      "enabled": true,
      "webhook_enabled": false
    },
    "slack": {
      "enabled": false,
      "webhook_url": ""
    },
    "cloudflare": {
      "enabled": true,
      "api_token_env": "CLOUDFLARE_API_TOKEN"
    }
  },
  "security": {
    "sandbox": true,
    "audit_log": true,
    "require_approval_for": [
      "production_deploy",
      "database_migration",
      "pricing_change",
      "payment_processing",
      "customer_data_access"
    ]
  },
  "monitoring": {
    "dashboard_port": 8000,
    "metrics_enabled": true,
    "prometheus_enabled": false,
    "alerting": {
      "email": "fredmourao@gmail.com",
      "slack": false
    }
  }
}
