# Database
DATABASE_URL=postgresql://medusa_user:senha@localhost:5432/shopvivaliz_medusa
DATABASE_LOGGING=false
DATABASE_EXTRA_LOGGING=false

# Backend Configuration
NODE_ENV=development
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_BACKEND_URL=http://localhost:9000

# Admin
ADMIN_CORS=http://localhost:7001,http://localhost:8000
STORE_CORS=http://localhost:8000,http://localhost:3000

# Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_prod
COOKIE_SECRET=your_cookie_secret_key_here_change_in_prod

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# File Storage
FILE_STORAGE_DRIVER=local

# Marketplace APIs
SHOPEE_API_KEY=your_shopee_key
SHOPEE_API_SECRET=your_shopee_secret
SHOPEE_SHOP_ID=your_shopee_shop_id

AMAZON_ACCESS_KEY=your_amazon_key
AMAZON_SECRET_KEY=your_amazon_secret

OLIST_CLIENT_ID=your_olist_client_id
OLIST_CLIENT_SECRET=your_olist_secret

# EHA Integration
EHA_WEBHOOK_SECRET=your_eha_webhook_secret_change_in_prod
MEDUSA_WEBHOOK_URL=https://dev.shopvivaliz.com.br/claude/api/medusa-webhook.php
EHA_WEBHOOK_ENABLED=true

# Email (optional)
SENDGRID_API_KEY=
SENDER_EMAIL=noreply@shopvivaliz.com.br

# Logging
LOG_LEVEL=info
