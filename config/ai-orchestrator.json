{
  "workflow": "ai-engineering-platform",
  "version": "1.0.0",
  "agents": {
    "olist-sync": {
      "enabled": true,
      "trigger": "product_update",
      "constraints": ["no_price_modification"]
    },
    "image-optimization": {
      "enabled": true,
      "trigger": "image_upload",
      "constraints": ["no_price_modification"]
    },
    "checkout-optimization": {
      "enabled": true,
      "trigger": "cart_update",
      "constraints": ["no_price_modification"]
    },
    "freight-calculation": {
      "enabled": true,
      "trigger": "shipping_request",
      "constraints": ["no_price_modification"]
    }
  },
  "financial_safeguards": {
    "guardian_of_price": {
      "enabled": true,
      "enforcement_level": "strict"
    },
    "price_change_prohibition": true,
    "financial_rule_enforcement": "orchestrator_level"
  },
  "audit_requirements": {
    "log_all_operations": true,
    "immutable_audit_trail": true,
    "compliance_verification": "required"
  },
  "execution_policy": {
    "isolated_environments": true,
    "rate_limiting": {
      "olist": "100_requests_per_minute",
      "pagarme": "50_requests_per_minute"
    },
    "state_change_logging": "mandatory"
  },
  "autonomous_architecture": {
    "sensor": {
      "enabled": true,
      "collects": ["catalog", "seo", "performance", "conversion", "marketplaces"]
    },
    "director": {
      "enabled": true,
      "strategy": "revenue_engine"
    },
    "executor": {
      "enabled": true,
      "allowed_domains": ["seo", "content", "product-pages", "performance", "catalog-sync"]
    },
    "validator": {
      "enabled": true,
      "checks": ["policy_guard", "audit_trail", "result_verification"]
    }
  },
  "growth_policy": {
    "revenue_engine": {
      "enabled": true,
      "prioritize_by": ["sales_flow", "conversion_impact", "seo_gap", "catalog_readiness"]
    },
    "learning_loop": {
      "enabled": true,
      "feedback_sources": ["task_queue", "reports", "catalog_metrics"]
    },
    "ads": {
      "autonomous_execution": false,
      "requires_human_approval": true,
      "daily_budget_limit_source": "environment_or_manual_approval"
    }
  },
  "director_global_coordination": {
    "enabled": true,
    "shared_agents": ["ChatGPT", "Roo", "Gemini", "Claude", "OtherActiveAgents"],
    "continuous_operation": true,
    "must_consult_before_next_task": ["tasks-queue.json", "docs/ai-phase-execution.md", "api/orchestrator/director.php"],
    "must_finalize_each_task_with": [
      "documentation_update",
      "self_audit",
      "audit_log",
      "director_report"
    ],
    "director_report_fields": [
      "completed_task",
      "changed_files",
      "tests_executed",
      "result",
      "risks",
      "next_suggested_task"
    ],
    "forbidden_actions": [
      "automatic_price_change",
      "campaign_publish_without_human_approval",
      "automatic_budget_increase",
      "financial_actions",
      "deploy_without_authorization",
      "unsafe_change_without_auditability",
      "remove_existing_functionality_without_validation"
    ]
  }
}
