{
  "system": {
    "name": "ShopVivaliz Autonomous System",
    "version": "1.0.0",
    "mode": "24/7-autonomous",
    "created_at": "2026-07-03T00:00:00Z",
    "status": "active"
  },
  "architecture": {
    "layers": [
      {
        "name": "Orchestrator",
        "description": "GitHub Actions central coordinator",
        "interval_minutes": 5,
        "components": [
          "autonomous-orchestrator.yml"
        ]
      },
      {
        "name": "Automation",
        "description": "Local Windows Task Scheduler automation",
        "interval_minutes": 2,
        "components": [
          "scripts/tri-environment-sync.js",
          "scripts/autonomous-sync.py",
          "scripts/autonomous-git-push.py",
          "scripts/autonomous-ftp-deploy.py"
        ]
      },
      {
        "name": "Execution",
        "description": "Task execution engines (Gemini, Claude, GPT)",
        "interval_minutes": 30,
        "components": [
          "scripts/task-executor.py"
        ]
      }
    ]
  },
  "operations": {
    "autopilot": {
      "enabled": true,
      "default": true,
      "mode": "autopilot_economy",
      "auto_execute_safe_actions": true,
      "preserve_human_approval_for": [
        "secrets_or_credentials",
        "price_changes",
        "payment_actions",
        "budget_increase",
        "campaign_publish_or_activation",
        "deploy_or_rollback",
        "push_direct_to_main",
        "destructive_git_or_filesystem_operations"
      ]
    },
    "ai_economy": {
      "enabled": true,
      "reasoning_effort": "low",
      "verbosity": "low",
      "prefer_local_first": true,
      "default_models": {
        "openai": "gpt-4o-mini",
        "anthropic": "claude-haiku-4-5-20251001",
        "gemini": "gemini-2.5-flash",
        "local": "mistral:7b-instruct-q4_K_M"
      },
      "daily_budget_usd": 1.0,
      "manual_approval_required_for_model_escalation": true
    },
    "git": {
      "auto_pull": {
        "enabled": true,
        "interval_minutes": 5,
        "strategy": "merge -X ours",
        "commit_message_prefix": "[AUTO-PULL]"
      },
      "auto_push": {
        "enabled": true,
        "interval_minutes": 10,
        "detect_changes": true,
        "commit_message_prefix": "[AUTO-PUSH]"
      }
    },
    "sync": {
      "tri_environment": {
        "enabled": true,
        "interval_minutes": 5,
        "runner": "scripts/tri-environment-sync.js",
        "source_of_truth": "GitHub",
        "environments": [
          "pc",
          "cloud",
          "oracle"
        ],
        "protected_branches": [
          "main",
          "master"
        ],
        "allowed_push_prefixes": [
          "feat/",
          "fix/",
          "chore/",
          "sync/"
        ]
      },
      "local_sync": {
        "enabled": true,
        "interval_minutes": 2,
        "source": "C:\\FRED\\site-shopvivaliz",
        "destination": "c:\\users\\user\\site-shopvivaliz",
        "bidirectional": true,
        "ignore_patterns": [
          ".git",
          "__pycache__",
          ".venv",
          "node_modules",
          ".env",
          "*.log",
          "logs/"
        ]
      }
    },
    "deploy": {
      "ftp": {
        "enabled": true,
        "interval_minutes": 15,
        "trigger": "on-change",
        "host_env_var": "FTP_HOST",
        "user_env_var": "FTP_USER",
        "pass_env_var": "FTP_PASS",
        "port": 21,
        "remote_path": "/public_html/",
        "retry_count": 3,
        "timeout_seconds": 30
      }
    },
    "health": {
      "check": {
        "enabled": true,
        "interval_minutes": 60,
        "components": [
          "git_status",
          "workflows",
          "python_files",
          "api_endpoints",
          "directories",
          "recent_logs",
          "disk_space"
        ]
      }
    }
  },
  "windows_task_scheduler": {
    "tasks": [
      {
        "name": "ShopVivaliz-AutoSync",
        "script": "scripts/tri-environment-sync.js",
        "interval_minutes": 2,
        "enabled": true,
        "run_level": "Highest"
      },
      {
        "name": "ShopVivaliz-AutoGitPull",
        "command": "git fetch origin main && git merge -X ours origin/main",
        "interval_minutes": 5,
        "enabled": true,
        "run_level": "Highest"
      },
      {
        "name": "ShopVivaliz-AutoGitPush",
        "script": "scripts/autonomous-git-push.py",
        "interval_minutes": 10,
        "enabled": true,
        "run_level": "Highest"
      },
      {
        "name": "ShopVivaliz-AutoFtpDeploy",
        "script": "scripts/autonomous-ftp-deploy.py",
        "interval_minutes": 15,
        "enabled": true,
        "run_level": "Highest"
      }
    ]
  },
  "github_actions": {
    "workflows": [
      {
        "name": "Autonomous Orchestrator",
        "file": ".github/workflows/autonomous-orchestrator.yml",
        "interval_minutes": 5,
        "purpose": "Central coordinator"
      },
      {
        "name": "Auto Git Pull",
        "file": ".github/workflows/auto-git-pull.yml",
        "interval_minutes": 5,
        "purpose": "Pull from remote"
      },
      {
        "name": "Auto Git Push",
        "file": ".github/workflows/auto-git-push.yml",
        "interval_minutes": 10,
        "purpose": "Push to remote"
      },
      {
        "name": "Auto FTP Deploy",
        "file": ".github/workflows/auto-ftp-deploy.yml",
        "interval_minutes": 15,
        "purpose": "Deploy to FTP"
      },
      {
        "name": "Health Check",
        "file": ".github/workflows/health-check.yml",
        "interval_minutes": 60,
        "purpose": "Validate system health"
      }
    ]
  },
  "required_environment_variables": {
    "ftp": [
      "FTP_HOST",
      "FTP_USER",
      "FTP_PASS",
      "FTP_PORT",
      "FTP_REMOTE_PATH"
    ],
    "ai_agents": [
      "GEMINI_API_KEY",
      "OPENAI_API_KEY"
    ],
    "git": [
      "PERSONAL_ACCESS_TOKEN"
    ]
  },
  "required_github_secrets": [
    "FTP_HOST",
    "FTP_USER",
    "FTP_PASS",
    "PERSONAL_ACCESS_TOKEN"
  ],
  "logging": {
    "directory": "logs/",
    "retention_days": 30,
    "log_files": [
      "autonomous-sync.log",
      "autonomous-sync.json",
      "tri-environment-sync.json",
      "autonomous-git-push.log",
      "autonomous-git-push.json",
      "autonomous-ftp-deploy.log",
      "autonomous-ftp-deploy.json",
      "health-check.log",
      "health-check.json",
      "orchestrator-report.json"
    ]
  },
  "deployment_strategy": {
    "zero_downtime": true,
    "rollback_enabled": true,
    "conflict_resolution": "auto-merge-with-ours-strategy",
    "notification_channels": [
      "git-log",
      "json-reports"
    ]
  },
  "monitoring": {
    "enabled": true,
    "dashboard_url": "https://shopvivaliz.com.br/admin/monitor/",
    "metrics_to_track": [
      "last_sync_time",
      "last_push_time",
      "last_deploy_time",
      "uncommitted_changes",
      "ftp_connection_status",
      "disk_usage",
      "system_health"
    ]
  }
}
