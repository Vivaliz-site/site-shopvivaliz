{
  "providerProfiles": {
    "currentApiConfigName": "default",
    "apiConfigs": {}
  },
  "globalSettings": {
    "customInstructions": "Trabalhe em piloto automatico economico dentro deste workspace: implemente, teste e registre evidencias sem perguntar quando houver uma acao segura. Use modelos/caminhos baratos por padrao. Preserve aprovacao humana para segredos, precos, pagamentos, orcamentos, campanhas, deploy/rollback, push direto em main e comandos destrutivos. Nunca use git reset --hard.",
    "autoApprovalEnabled": true,
    "alwaysAllowReadOnly": true,
    "alwaysAllowReadOnlyOutsideWorkspace": false,
    "alwaysAllowWrite": true,
    "alwaysAllowWriteOutsideWorkspace": false,
    "alwaysAllowWriteProtected": false,
    "alwaysAllowMcp": true,
    "alwaysAllowModeSwitch": true,
    "alwaysAllowSubtasks": true,
    "alwaysAllowExecute": true,
    "alwaysAllowFollowupQuestions": true,
    "followupAutoApproveTimeoutMs": 15000,
    "allowedCommands": [
      "git status",
      "git branch",
      "git checkout",
      "git switch",
      "git fetch",
      "git pull",
      "git add",
      "git commit",
      "git push",
      "git diff",
      "git show",
      "git log",
      "rg",
      "Get-ChildItem",
      "Get-Content",
      "Set-Location",
      "Select-String",
      "Test-Path",
      "Resolve-Path",
      "Copy-Item",
      "Move-Item",
      "New-Item",
      "php",
      "python",
      "node",
      "npm",
      "composer",
      "curl"
    ],
    "deniedCommands": [
      "git push origin main",
      "git push origin HEAD:main",
      "git push --force",
      "git push -f",
      "git reset --hard",
      "git checkout --",
      "git clean",
      "git branch -D",
      "Remove-Item -Recurse",
      "Remove-Item -Force",
      "del /f",
      "rmdir /s",
      "Format-Volume",
      "diskpart"
    ],
    "commandExecutionTimeout": 600,
    "autoCondenseContext": true,
    "includeCurrentTime": true,
    "includeCurrentCost": true,
    "maxGitStatusFiles": 200,
    "maxWorkspaceFiles": 10000,
    "showRooIgnoredFiles": false,
    "enableSubfolderRules": true,
    "terminalOutputPreviewSize": "medium"
  }
}
