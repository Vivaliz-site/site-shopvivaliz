{
  "openapi": "3.0.3",
  "info": {
    "title": "ShopVivaliz GraphQL API",
    "version": "1.0.0",
    "description": "Endpoint leve para consultas do frontend com rate limiting por IP."
  },
  "servers": [
    {
      "url": "https://dev.shopvivaliz.com.br"
    }
  ],
  "paths": {
    "/api/graphql.php": {
      "get": {
        "summary": "Executa uma consulta GraphQL simples",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "{ products(limit: 3) { id sku name price stock } }"
          },
          {
            "name": "variables",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Consulta aceita"
          },
          "400": {
            "description": "Query ausente ou invalida"
          },
          "429": {
            "description": "Rate limit excedido"
          }
        }
      },
      "post": {
        "summary": "Executa uma consulta GraphQL simples",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "variables": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              },
              "examples": {
                "products": {
                  "value": {
                    "query": "{ products(limit: 5, q: \"rodizio\") { id sku name price stock image_url } }"
                  }
                },
                "product": {
                  "value": {
                    "query": "{ product(id: \"342902731\") { id sku name price stock category } }"
                  }
                },
                "stats": {
                  "value": {
                    "query": "{ stats { catalog_count orders_count feedback_count generated_at } }"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Consulta aceita"
          },
          "400": {
            "description": "Query ausente ou invalida"
          },
          "413": {
            "description": "Payload muito grande"
          },
          "429": {
            "description": "Rate limit excedido"
          }
        }
      },
      "options": {
        "summary": "Preflight CORS/HTTP"
      }
    }
  }
}
